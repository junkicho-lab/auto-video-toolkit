# =========================================================
#  Auto-Video Toolkit — API 키 설정
#  이 파일을 config/api-keys.env 로 복사한 뒤 사용할 값만 채우세요.
#  (사용하지 않는 provider의 키는 비워둬도 됩니다.)
# =========================================================

# --- 이미지 생성: GPT Image 2 (ima2) ---
# 방법 A(기본): Codex OAuth 로그인 → `npx @openai/codex login` (키 불필요)
# 방법 B: OpenAI API 키로 직접 호출할 때만 설정
# OPENAI_API_KEY=your-openai-api-key

# --- 영상 생성: config/models.yaml 의 video_generation 으로 provider 선택 ---
# (veo | grok | kling | higgsfield) — 선택한 provider의 키만 채우면 됩니다.
GEMINI_API_KEY=your-gemini-api-key          # veo(Google) + 리서치/대본/이미지프롬프트 공용
XAI_API_KEY=your-xai-api-key                # grok (xAI)
KLING_ACCESS_KEY=your-kling-access-key      # kling (JWT 발급용 Access Key)
KLING_SECRET_KEY=your-kling-secret-key      # kling (JWT 서명용 Secret Key)
SEGMIND_API_KEY=your-segmind-api-key        # higgsfield (Segmind 호스팅 경유)

# --- 나레이션 (TTS) ---
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# --- LLM provider: Claude (autovideo --llm claude 사용 시) ---
# ANTHROPIC_API_KEY=your-anthropic-api-key   # 발급: https://console.anthropic.com
